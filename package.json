{
  "name": "fluxa",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "cd services/nasemby-core && python -m app.main",
    "typecheck": "tsc -p tsconfig.app.json",
    "build": "npm run typecheck && vite build",
    "test": "npm run typecheck",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.5.3",
    "vite": "^6.4.3"
  }
}
