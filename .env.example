# Whole-site access protection. Production refuses to start when the key is empty
# or shorter than 16 characters. Use a random value of at least 32 characters.
MCC_ACCESS_KEY=
# Optional comma-separated exact origins, for example https://media.example.com
MCC_ALLOWED_ORIGINS=
# Leave empty for the production default (true). Set false only for trusted HTTP tests.
MCC_COOKIE_SECURE=
# Python unified runtime only. The final image sets this to the copied Vite dist directory.
MCC_FRONTEND_DIST=
# Keep these false for deployment-only/read-only acceptance. Enable them only in a controlled subscription test window.
MCC_SUBSCRIPTION_SCHEDULER_ENABLED=false
NASEMBY_CORE_WRITE_ENABLED=false
# Private PT RSS collection. Source configuration can be saved while this remains false;
# no feed URL is read and no external RSS request is made until it is enabled.
MCC_PRIVATE_RSS_ENABLED=false
# RSS 唤醒与主动兜底共用的 Torra 追更洗版总闸门；保持关闭时不会提交分析任务。
MCC_TORRA_QUALITY_WATCH_ENABLED=false
# Manual candidate download remains independent from analysis and automatic observation.
MCC_TORRA_REWASH_DOWNLOAD_ENABLED=false
# Manual MoviePilot fallback after every related Torra quality-watch window has expired.
# Keep false unless a single controlled fallback action has been approved.
MCC_MOVIEPILOT_BACKUP_ENABLED=false
# Preserved NasEmby management/core routes remain in source for migration tests.
# Never enable this global compatibility switch in production; new APIs use smaller per-action gates.
MCC_PRESERVED_CORE_API_ENABLED=false
# NasEmby integrations and cloud acquisition. All remain false until a controlled test window.
MCC_INTEGRATION_PROBE_ENABLED=false
MCC_INTEGRATION_MANAGEMENT_ENABLED=false
MCC_TELEGRAM_MANAGEMENT_ENABLED=false
MCC_HDHIVE_MANAGEMENT_ENABLED=false
MCC_CLOUD_SEARCH_ENABLED=false
MCC_CLOUD_TRANSFER_ENABLED=false
# fnOS host directory containing data/, db/, and upload/.
MCC_DATA_ROOT=./runtime

# Emby
EMBY_BASE_URL=
EMBY_API_KEY=
EMBY_USER_ID=
EMBY_USERNAME=
EMBY_PASSWORD=

# qBittorrent and Torra
QB_BASE_URL=
QB_USERNAME=
QB_PASSWORD=
TORRA_BASE_URL=
TORRA_TOKEN=
TORRA_USERNAME=
TORRA_PASSWORD=
TORRA_PUSH_ENABLED=false
TORRA_DOWNLOAD_ROOT=
TORRA_DOWNLOADER_ID=

# Symedia, TMDB, and Mineradio
SYMEDIA_BASE_URL=
SYMEDIA_TOKEN=
SYMEDIA_USERNAME=
SYMEDIA_PASSWORD=
# Use one TMDB credential: legacy v3 API key or v4 Bearer token.
TMDB_API_KEY=
TMDB_API_TOKEN=
MINERADIO_PUBLIC_DIR=

# NasEmby 115 / Telegram / HDHive / MoviePilot compatibility settings
ENV_115_COOKIES=
ENV_UPLOAD_PID=0
ENV_TG_PHONE=
ENV_TG_API_ID=
ENV_TG_API_HASH=
ENV_HDHIVE_CHECKIN_ENABLED=0
ENV_MOVIEPILOT_URL=
ENV_MOVIEPILOT_API_TOKEN=
